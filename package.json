{
  "name": "mcp-md2pdf",
  "version": "1.3.2",
  "description": "Convert Markdown to beautiful PDFs. MCP server, CLI, and programmatic API. Supports Mermaid diagrams, KaTeX math, syntax highlighting, tables, and auto-generated Table of Contents.",
  "main": "dist/index.js",
  "type": "module",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/mcp-server.js",
      "types": "./dist/mcp-server.d.ts"
    }
  },
  "bin": {
    "mcp-md2pdf": "dist/mcp-server.js",
    "m2p": "dist/mcp-server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "preprepublishOnly": "node scripts/auto-version.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "pdf",
    "markdown",
    "mermaid",
    "model-context-protocol",
    "library",
    "api",
    "katex",
    "syntax-highlighting"
  ],
  "author": "PDF Generator MCP Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/neang-mengseang/MCP-MD2Pdf.git"
  },
  "bugs": {
    "url": "https://github.com/neang-mengseang/MCP-MD2Pdf/issues"
  },
  "homepage": "https://github.com/neang-mengseang/MCP-MD2Pdf#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "md2pdf-core": "^1.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
