{
  "name": "mcp-md2pdf",
  "version": "1.0.0",
  "description": "MCP server that converts Markdown to beautiful PDFs. Supports Mermaid diagrams, syntax highlighting, tables, and auto-generated Table of Contents.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "mcp-md2pdf": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "pdf",
    "markdown",
    "mermaid",
    "model-context-protocol"
  ],
  "author": "PDF Generator MCP Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/mcp-md2pdf.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/mcp-md2pdf/issues"
  },
  "homepage": "https://github.com/yourusername/mcp-md2pdf#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "highlight.js": "^11.11.0",
    "katex": "^0.16.21",
    "marked": "^15.0.0",
    "marked-highlight": "^2.2.0",
    "mermaid": "^10.9.0",
    "puppeteer-core": "^23.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/katex": "^0.16.7",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
